# Personality Core MCP Server Configuration

# Personalities root (Chinese project root)
PERSONALITY_PROJECT_ROOT=C:/Users/13534/Desktop/渊

# Data file for training
PERSONALITY_DATA_FILE=C:/Users/13534/Desktop/渊/data/full_personas.json

# Saved model path for fast loading
PERSONALITY_MODEL_PATH=C:/Users/13534/Desktop/渊/models/personality_model

# Ollama LLM settings (optional, for chat)
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=qwen3:8b

# Safety defaults
SANITIZATION_MAX_INPUT_LENGTH=2000
SANITIZATION_ENABLED=true

# Logging
LOGGING_LEVEL=INFO
LOGGING_FILE_PATH=./logs/personality_core.log

# Memory DB
MEMORY_DB_DATA_DIR=./memory_data
MEMORY_DB_WAL_MODE=true

# Rate Limit
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_MAX_REQUESTS=30

# Session
SESSION_TTL_SECONDS=3600
SESSION_LRU_MAX=50
